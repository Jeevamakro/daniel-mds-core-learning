                                                  {%- endif -%}
                                                </div>
                                              </div>
                                            </div>
                                            {{- -}}
                                            {{- -}}
                                          {%- endcapture -%}
                                        {%- endif -%}
                                        {{- -}}
                                      {%- endfor -%}
                                      {{- -}}
                                      <li class="view-all-link">
                                        <a href="{{innerlink.url}}" class="mobile-menu__nav-link">View all</a>
                                      </li>
                                    </ul>
                                  </div>
                                  {{- -}}
                                  {{- forth_level_menu -}}
                                </div>
                              {%- endcapture -%}
                              {{- -}}
                            {%- endif -%}
                          {%- endfor -%}
                          {{- -}}
                        </ul>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              {{- -}}
              {{- third_level_menu  | strip_newlines | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' -}}
