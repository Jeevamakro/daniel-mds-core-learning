                                                            </svg></i>
                                                            <span>{{splithtml_guide[0]}}</span>
                                                          </a>
                                                        {%- endfor -%}
                                                      {%- else -%}
                                                        {%- assign splithtml_guide = guidehtml | split:',' -%}
