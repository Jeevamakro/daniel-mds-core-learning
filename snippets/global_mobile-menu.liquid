                                                        {%- assign handle_obj_old = innerchild.url | replace:'/collections/','' -%}
                                                        {%- assign handle_obj = collections[handle_obj_old] -%}
                                                        {%- if handle_obj.products.size > 0 -%}
                                                          <li data-type="{{ innerchild.type }}"><a href="{{innerchild.url}}" class="mobile-menu__nav-link">{{innerchild.title}}</a></li>
                                                        {%- endif -%}
                                                      {%- else -%}
