{% comment %} {%- capture media_cap -%}media="(min-width: 1000px)"{%- endcapture -%} {% endcomment %}
{{ 'global_desktop-menu.css' | asset_url | stylesheet_tag | replace:'media="all"', media_cap }}

<div class="main-navigation">
  <ul class="first-lavel list-unstyled">
    {%- for link in linklists[section.settings.menu].links -%}

      {%- assign has_megamenu = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'mega_menu_block' -%}
          {%- assign blockmenu_title = block.settings.menu-title | handleize -%}
          {%- if blockmenu_title == link.handle -%}
            {%- assign has_megamenu = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_megamenu == true  -%}
        <li class="mega-nav">
          <a href="{{link.url}}">
            
            {{link.title}}
          </a>
          {% comment %} <noscript class="contentString"> {% endcomment %}
            
            {% comment %} {%- capture noscript_cap -%} {% endcomment %}
            {%- for block in section.blocks -%}
              {%- if block.type == 'mega_menu_block' -%}
                {%- assign blockmenu_title = block.settings.menu-title | handleize -%}
                {%- if blockmenu_title == link.handle -%}
                  {%- if block.settings.inner_menu_list != blank -%}
                    <div class="mega-main-wrapper comm-drop-menu">
                      <div class="menu-wrapper container no-third-child">
                        <ul class="child-level-one">
                          {%- for innerlink in linklists[block.settings.inner_menu_list].links -%}
                          <li data-title="{{innerlink.title}}" class="{% if innerlink.links != blank %}has-dropdown{% endif %} sublevel-menu {% if forloop.first %}open active{% endif %}">
                            
                            <span class="link-item">
                              {%- assign file_name = innerlink.title | handle | append: '.svg' | file_url -%}
                              {%- assign appendEx = '.svg' -%}
                              {%- unless file_name contains '?v=' -%}
                                {%- assign file_name = innerlink.title | handle | append: '.png' | file_url -%}
                                {%- assign appendEx = '.png' -%}  
                              {%- endunless -%}
                              {%- if file_name contains '?v=' -%}
                                <i class="cat-icon"><img src="{{ innerlink.title | handle | append:appendEx  | file_url }}" alt="{{ innerlink.title }}"></i>
                              {%- endif -%}
                              
                              {%- if innerlink.links != blank -%}
                                <span>{{innerlink.title}}</span>
                                <span class="right-arrow">
                                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                                    <path d="M4.89844 11.8999L9.79844 6.9999L4.89844 2.0999" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                </span>
                              {%- else -%}
                                <a href="{{ innerlink.url }}">{{ innerlink.title }}</a>
                              {%- endif -%}
                            </span>
                            

                            {%- if innerlink.links != blank -%}
                            <ul class="child-level-two">
                              
                              {%- assign third_child_cap = blank  -%}
                              {%- if innerlink.url != '#' -%}
                                <li class="view-all">
                                  <span>{{innerlink.title}}</span>
                                  <a href="{{innerlink.url}}" class="view-all link-item">View All {%- render 'icon', icon: 'arrow-right' -%}</a>
                                </li>
                              {%- endif -%}
                              {%- for childlink in innerlink.links -%}
                                {%- assign guide_counter = 0 -%}
                                <li class="{% if childlink.links != blank %}has-dropdown{% else %}no-dropdown{% endif %} inner-li {% if forloop.first %}open{% endif %}" data-hover-content="{{ childlink.title | handle }}-{{ forloop.index }}--{{  forloop.parentloop.index }}">

                                  {%- if childlink.links != blank -%}
                                    <span class="link-item">
                                      <span>{{childlink.title}}</span>
                                      {%- if childlink.links != blank -%}
                                      <span class="right-arrow">
                                        <svg focusable="false" class="icon icon--arrow-right" viewBox="0 0 8 12" role="presentation">
                                          <path stroke="currentColor" stroke-width="2" d="M2 2l4 4-4 4" fill="none" stroke-linecap="square"></path>
                                        </svg>
                                      </span>
                                      {%- endif -%}
                                    </span>
                                  {%- else -%}
                                    <a href="{{childlink.url}}" class="link-item"><span>{{childlink.title}}</span>
                                      {%- if childlink.links != blank -%}<span class="right-arrow">{%- render 'icon', icon: 'arrow-right' -%}</span>{%- endif -%}
                                    </a>
                                  {%- endif -%}

                                  {%- capture third_child_cap -%}
                                    {{- third_child_cap | strip_newlines -}}
                                    {%- if childlink.links != blank -%}
                                      {%- assign count_grid = 0 -%}
                                      {%- for innerchild in childlink.links -%}
                                        {%- unless innerchild.handle contains 'guide' -%}
                                          {%- assign count_grid = count_grid | plus:1 -%}
                                        {%- endunless -%}
                                      {%- endfor -%}

                                      {%- for block in section.blocks -%}
                                        {%- assign downcase_block_menu_item = block.settings.menu_item | downcase | strip -%}
                                        {%- assign downcase_title = innerlink.title | downcase | strip -%}
                                        {%- assign curentDate = 'now' | date: '%Y-%m-%d' | date: '%s' -%}
                                        {%- assign promo1Flag = false -%}
                                        {%- assign promo2Flag = false -%}
                                        {%- assign promo3Flag = false -%}
                                        {%- assign promo4Flag = false -%}
                                        {%- assign promo5Flag = false -%}
                                        {%- assign promo6Flag = false -%}
                                        {%- assign mainCount = 0 -%}
                                      
                                        {%- if downcase_block_menu_item == downcase_title -%}
                                      
                                          {%- capture promotion_text -%}
                                            {%- if block.settings.promo_1_st_date != blank and block.settings.promo_1_end_date != blank -%}
                                              {%- assign startDate = block.settings.promo_1_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                              {%- assign endDate = block.settings.promo_1_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                              {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                {%- if block.settings.promo_1_text != blank -%}
                                                  {%- assign promo1Flag = true -%}
                                                  {%- assign mainCount = mainCount | plus: 1 -%}
                                                  <a href="{%- if block.settings.promo_1_banner_link != blank -%}{{block.settings.promo_1_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_1_text}}</a>
                                                {%- endif -%}
                                              {%- endif -%}
                                            {%- endif -%}
                                      
                                          {%- if block.settings.promo_2_st_date != blank and block.settings.promo_2_end_date != blank -%}
                                              {%- assign startDate = block.settings.promo_2_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                              {%- assign endDate = block.settings.promo_2_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                              {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                {%- if block.settings.promo_2_text != blank -%}
                                                  {%- assign promo2Flag = true -%}
                                                  {%- assign mainCount = mainCount | plus: 1 -%}
                                                  <a href="{%- if block.settings.promo_2_banner_link != blank -%}{{block.settings.promo_2_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_2_text}}</a>
                                                {%- endif -%}
                                              {%- endif -%}
                                            {%- endif -%}
                                      
                                        {%- if mainCount < 3 -%}
                                              {%- if block.settings.promo_3_st_date != blank and block.settings.promo_3_end_date != blank -%}
                                                {%- assign startDate = block.settings.promo_3_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- assign endDate = block.settings.promo_3_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                  {%- if block.settings.promo_3_text != blank -%}
                                                    {%- assign promo3Flag = true -%}
                                                    {%- assign mainCount = mainCount | plus: 1 -%}
                                                    <a href="{%- if block.settings.promo_3_banner_link != blank -%}{{block.settings.promo_3_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_3_text}}</a>
                                                  {%- endif -%}
                                                {%- endif -%}
                                              {%- endif -%}
                                        {%- endif -%}
                                      
                                        {%- if mainCount < 3 -%}
                                              {%- if block.settings.promo_4_st_date != blank and block.settings.promo_4_end_date != blank -%}
                                                {%- assign startDate = block.settings.promo_4_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- assign endDate = block.settings.promo_4_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                  {%- if block.settings.promo_4_text != blank -%}
                                                    {%- assign promo4Flag = true -%}
                                                    {%- assign mainCount = mainCount | plus: 1 -%}
                                                    <a href="{%- if block.settings.promo_4_banner_link != blank -%}{{block.settings.promo_4_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_4_text}}</a>
                                                  {%- endif -%}
                                                {%- endif -%}
                                              {%- endif -%}
                                        {%- endif -%}
                                      
                                        {%- if mainCount < 3 -%}
                                              {%- if block.settings.promo_5_st_date != blank and block.settings.promo_5_end_date != blank -%}
                                                {%- assign startDate = block.settings.promo_5_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- assign endDate = block.settings.promo_5_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                  {%- if block.settings.promo_5_text != blank -%}
                                                    {%- assign promo5Flag = true -%}
                                                    {%- assign mainCount = mainCount | plus: 1 -%}
                                                    <a href="{%- if block.settings.promo_5_banner_link != blank -%}{{block.settings.promo_5_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_5_text}}</a>
                                                  {%- endif -%}
                                                {%- endif -%}
                                              {%- endif -%}
                                        {%- endif -%}
                                      
                                        {%- if mainCount < 3 -%}
                                              {%- if block.settings.promo_6_st_date != blank and block.settings.promo_6_end_date != blank -%}
                                                {%- assign startDate = block.settings.promo_6_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- assign endDate = block.settings.promo_6_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                                                {%- if startDate <= curentDate and endDate >= curentDate -%}
                                                  {%- if block.settings.promo_6_text != blank -%}
                                                    {%- assign promo6Flag = true -%}
                                                    {%- assign mainCount = mainCount | plus: 1 -%}
                                                    <a href="{%- if block.settings.promo_6_banner_link != blank -%}{{block.settings.promo_6_banner_link}}{%- else -%}javascript:void(0);{%- endif -%}">{{block.settings.promo_6_text}}</a>
                                                  {%- endif -%}
                                                {%- endif -%}
                                              {%- endif -%}
                                              {%- endif -%}
                                          {%- endcapture -%}
                                          
                                        
                                          
                                        {%- endif -%}
                                      {%- endfor -%}
                                      <div class="child-level-three {% if count_grid > 24 %}big-grid{% endif %} {% if guidehtml == '' %}no-guide{% endif %}" data-hover="{{ childlink.title | handle }}-{{ forloop.index }}--{{  forloop.parentloop.index }}"
                                       
                                      >
                                        <ul>                                        
                                          {%- if childlink.url != blank -%}
                                            <li class="view-all">
                                              <span>{{childlink.title}}</span>
                                              <a href="{{childlink.url}}" class="view-all link-item">View All {%- render 'icon', icon: 'arrow-right' -%}</a>
                                            </li>                                                  
                                          {%- endif -%}
                                          {%- assign guidecounter = 0 -%}
                                          {%- assign guidehtml = '' -%}
                                          {%- for innerchild in childlink.links -%}
                                            {%- if innerchild.handle contains 'guide' -%}
                                              {%- if guide_counter == 0 -%}
                                                {%- assign guidehtml = innerchild.title | append:',' | append:innerchild.url -%}
                                              {%- else -%}
                                                {%- assign guidehtml = guidehtml | append:'|' | append:innerchild.title | append:',' | append:innerchild.url -%}
                                              {%- endif -%}
                                              {%- assign guide_counter = guide_counter | plus:1 -%}
                                            {%- else -%}
                                              {%- if innerchild.type == 'collection_link' -%}
                                                {%- assign handle_obj_old = innerchild.url | replace:'/collections/','' -%}
                                                {%- assign handle_obj = collections[handle_obj_old] -%}
                                                {%- if handle_obj.products.size > 0 -%}
                                                <li data-type="{{ innerchild.type }}"><a href="{{innerchild.url}}" class="link-item">{{innerchild.title}}</a></li>
                                                {%- endif -%}
                                              {%- else -%}
                                                <li data-type="{{ innerchild.type }}"><a href="{{innerchild.url}}" class="link-item">{{innerchild.title}}</a></li>
                                              {%- endif -%}
                                            {%- endif -%}
                                          {%- endfor -%}
                                        </ul>
                                      </div>
                                      
                                    {%- endif -%}
                                  {%- endcapture -%}
                                </li>
                              {%- endfor -%}
                              
                            </ul>
                            {%- endif -%}
                            <div class="child-level-two child-level-two--childs">{{ third_child_cap }}</div>
                          </li>
                        {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- break -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {% comment %} {%- endcapture -%}{{ noscript_cap | strip_newlines | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' }} {% endcomment %}
            
          {% comment %} </noscript> {% endcomment %}
        </li>
      {%- else -%}
        
        <li {% if link.title == 'Brands' %}id="{{ link.title | handleize }}"{% endif %} class="{% if link.title == 'Brands' %}brands{% endif %}">          
          {%- if link.title == 'Brands' -%}
            <a href="{{link.url}}" class="{% if link.active %} link-active{% endif %}">{{link.title}}</a>
            {% comment %} <noscript class="contentString"> {% endcomment %}
              
              {% comment %} {%- capture noscript_cap -%} {% endcomment %}
              <div id="{{ link.title | handleize }}-inner" class="comm-drop-menu brand-menu-wrapper" {{ mega_menu_block.shopify_attributes }}>
                {%- assign brand_menu = linklists['shop-by-brand'] -%}
                <div class="brand-mega-menu-list">
                  <div class="brand-mega-menu-sidebar">
                    <ul>
                      {%- for link_1 in brand_menu.links -%}
                        <li {% if forloop.first %}class="active"{% endif %}>
                          <a href="#" data-tab-title="{{ link_1.handle }}">{{link_1.title}} 
                            <span class="right-arrow">
                              <svg focusable="false" class="icon icon--arrow-right" viewBox="0 0 8 12" role="presentation">
                                <path stroke="currentColor" stroke-width="2" d="M2 2l4 4-4 4" fill="none" stroke-linecap="square"></path>
                              </svg>
                            </span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  <div class="brand-mega-menu-content">
                    {%- for link_1 in brand_menu.links -%}
                      <div class="inner_div_wrap {% if forloop.first %}active{% endif %}" data-tab-title="{{ link_1.handle }}">
                        <div class="mega_menu_top_title">
                          <h4>{{ link_1.title }}</h4>
                        </div>
                        <div class="mega-menu__inner ">
                          <ul class="mega-menu__linklist">
                            {%- for link_2 in link_1.links -%}
                              <li class="mega-menu__item">
                                <a href="{{ link_2.url }}" class="mega-menu__link link">{{ link_2.title }}</a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
              {% comment %} {%- endcapture -%}{{ noscript_cap | strip_newlines | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' | replace:'  ',' ' }} {% endcomment %}
              
            {% comment %} </noscript>{% endcomment %}
          {%- else -%}
            <a href="{{link.url}}" class="anchor-link{% if link.active %} link-active{% endif %}">{{link.title}}</a>
            {%- if link.links != blank -%}
              <div class="comm-drop-menu dropdown-menu">
                <ul>
                  {%- for maininner in link.links -%}
                  <li><a href="{{maininner.url}}">{{maininner.title}}</a></li>
                  {%- endfor -%}
                </ul>
                {%- for block in section.blocks -%}
                  {%- assign downcase_block_menu_item = block.settings.menu_item | downcase | strip -%}
                  {%- assign downcase_title = link.title | downcase | strip -%}
                  {%- assign curentDate = 'now' | date: '%Y-%m-%d' | date: '%s' -%}
                  {%- assign promo1Flag = false -%}
                  {%- assign promo2Flag = false -%}
                  {%- assign promo3Flag = false -%}
                  {%- assign promo4Flag = false -%}
                  {%- assign promo5Flag = false -%}
                  {%- assign promo6Flag = false -%}
                  {%- assign mainCount = 0 -%}

                  {%- if downcase_block_menu_item == downcase_title -%}

                  {%- capture promotion_text -%}
                  {%- if block.settings.promo_1_st_date != blank and block.settings.promo_1_end_date != blank -%}
                  {%- assign startDate = block.settings.promo_1_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                  {%- assign endDate = block.settings.promo_1_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                  {%- if startDate <= curentDate and endDate >= curentDate -%}
                  {%- if block.settings.promo_1_text != blank -%}
                  {%- assign promo1Flag = true -%}
                  {%- assign mainCount = mainCount | plus: 1 -%}
                  <a href="{% if block.settings.promo_1_banner_link != blank %}{{block.settings.promo_1_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_1_text}}</a>
                  {%- endif -%}
                  {%- endif -%}
                  {%- endif -%}

                  {%- if block.settings.promo_2_st_date != blank and block.settings.promo_2_end_date != blank -%}
                  {%- assign startDate = block.settings.promo_2_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                  {%- assign endDate = block.settings.promo_2_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                  {%- if startDate <= curentDate and endDate >= curentDate -%}
                  {%- if block.settings.promo_2_text != blank -%}
                  {%- assign promo2Flag = true -%}
                  {%- assign mainCount = mainCount | plus: 1 -%}
                  <a href="{% if block.settings.promo_2_banner_link != blank %}{{block.settings.promo_2_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_2_text}}</a>
                  {%- endif -%}
                  {%- endif -%}
                  {%- endif -%}

                  {%- if mainCount < 3 -%}
                    {%- if block.settings.promo_3_st_date != blank and block.settings.promo_3_end_date != blank -%}
                    {%- assign startDate = block.settings.promo_3_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- assign endDate = block.settings.promo_3_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- if startDate <= curentDate and endDate >= curentDate -%}
                    {%- if block.settings.promo_3_text != blank -%}
                    {%- assign promo3Flag = true -%}
                    {%- assign mainCount = mainCount | plus: 1 -%}
                    <a href="{% if block.settings.promo_3_banner_link != blank %}{{block.settings.promo_3_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_3_text}}</a>
                    {%- endif -%}
                    {%- endif -%}
                    {%- endif -%}
                    
                    {%- if block.settings.promo_4_st_date != blank and block.settings.promo_4_end_date != blank -%}
                    {%- assign startDate = block.settings.promo_4_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- assign endDate = block.settings.promo_4_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- if startDate <= curentDate and endDate >= curentDate -%}
                    {%- if block.settings.promo_4_text != blank -%}
                    {%- assign promo4Flag = true -%}
                    {%- assign mainCount = mainCount | plus: 1 -%}
                    <a href="{% if block.settings.promo_4_banner_link != blank %}{{block.settings.promo_4_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_4_text}}</a>
                    {%- endif -%}
                    {%- endif -%}
                    {%- endif -%}
                    
                    {%- if block.settings.promo_5_st_date != blank and block.settings.promo_5_end_date != blank -%}
                    {%- assign startDate = block.settings.promo_5_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- assign endDate = block.settings.promo_5_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- if startDate <= curentDate and endDate >= curentDate -%}
                    {%- if block.settings.promo_5_text != blank -%}
                    {%- assign promo5Flag = true -%}
                    {%- assign mainCount = mainCount | plus: 1 -%}
                    <a href="{% if block.settings.promo_5_banner_link != blank %}{{block.settings.promo_5_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_5_text}}</a>
                    {%- endif -%}
                    {%- endif -%}
                    {%- endif -%}
                    
                    {%- if block.settings.promo_6_st_date != blank and block.settings.promo_6_end_date != blank -%}
                    {%- assign startDate = block.settings.promo_6_st_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- assign endDate = block.settings.promo_6_end_date | date: '%Y-%m-%d' | date: '%s' -%}
                    {%- if startDate <= curentDate and endDate >= curentDate -%}
                    {%- if block.settings.promo_6_text != blank -%}
                    {%- assign promo6Flag = true -%}
                    {%- assign mainCount = mainCount | plus: 1 -%}
                    <a href="{% if block.settings.promo_6_banner_link != blank %}{{block.settings.promo_6_banner_link}}{% else %}javascript:void(0);{% endif %}">{{block.settings.promo_6_text}}</a>
                    {%- endif -%}
                    {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                  {%- endcapture -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</div>
