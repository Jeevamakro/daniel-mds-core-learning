<section class="hover-stack color-{{ section.settings.color_scheme }}">
  <div class="page-width">

    <h2>{{ section.settings.heading }}</h2>

    <div class="card-stack">
      {% for block in section.blocks %}
        <div class="card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img 
              src="{{ block.settings.image | image_url: width: 600 }}" 
              alt="{{ block.settings.title }}"
              loading="lazy">
          {% endif %}
          <div class="card-info">
            <h3>{{ block.settings.title }}</h3>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>
<style>
    .hover-stack {
  padding: 100px 0;
  text-align: center;
}

.hover-stack h2 {
  font-size: 40px;
  margin-bottom: 60px;
}

.card-stack {
  display: flex;
  justify-content: center;
  gap: 40px;
  flex-wrap: wrap;
  perspective: 1000px;
}

.card {
  width: 280px;
  height: 380px;
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  transition: 0.4s ease;
  transform-style: preserve-3d;
}

.card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-info {
  position: absolute;
  bottom: 0;
  width: 100%;
  padding: 20px;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  color: #fff;
}

.card:hover {
  transform: rotateY(10deg) rotateX(5deg) scale(1.05);
}
</style>
{% schema %}
{
  "name": "Hover Stack Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Featured Collection"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "default": "Product Title"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Hover Stack Cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}