<script>
    document.addEventListener('DOMContentLoaded', function() {
        checkforlists();
    });

    function createList(ele){
        document.querySelector('.empty-text').classList.add('hidden');
        document.querySelector('.list-created').classList.remove('hidden');
        if(!document.querySelector('.lists-layout').classList.contains('hidden')){
            document.querySelector('.lists-layout').classList.add('hidden');
        }
        ele.classList.add('hidden');
    }

    function backbutton(ele){
        document.querySelector('.list-created').classList.add('hidden');
        checkforlists();
    }

    function checkforlists(){
        var hasMyLists = !!localStorage.getItem('mylists');
        document.querySelector('[onclick="createList(this)"]').classList.remove('hidden');
        if(hasMyLists && JSON.parse(localStorage.getItem('mylists')).length == 0){
          document.querySelector('.empty-text').classList.remove('hidden');
          document.querySelector('.list-created').classList.add('hidden');
          document.querySelector('.create-list-section').classList.remove('hidden');
          return;
        }
        if(hasMyLists){
            document.querySelector('.empty-text').classList.add('hidden');
            {% comment %} document.querySelector('.list-created').classList.remove('hidden'); {% endcomment %}
            document.querySelector('.lists-layout').classList.remove('hidden');
            {% comment %} document.querySelector('.create-list-section').classList.remove('hidden'); {% endcomment %}
            addsavedEntry(localStorage.getItem('mylists'));
        }else{
            document.querySelector('.empty-text').classList.remove('hidden');
            document.querySelector('.list-created').classList.add('hidden');
            document.querySelector('.create-list-section').classList.remove('hidden');
        }
        document.querySelector('[onclick="createList(this)"]').classList.remove('hidden');
    }

    function searchProd(ele){
        var get_search_term = ele.value;
        fetch(`/search?q=${get_search_term}&type=product&section_id=template--20490542710997__cheksection`)
        .then((response) => response.text())
        .then((responseText) => {
            const html = new DOMParser().parseFromString(responseText, 'text/html')
            const get_html = html.querySelector('.result-div').textContent.trim();
            {% comment %} if(get_html == 'No Products'){console.log('no products');}else{console.log('have products');} {% endcomment %}
            document.querySelector('.suggested-product-list').innerHTML = html.querySelector('.result-div').innerHTML;
            document.querySelector('.suggested-product-list').classList.remove('hidden');
        })
        .catch((e) => {
            console.error(e)
        })
    }

    function addprodlist(ele){
        var main_div = ele.closest('.suggested-product');
        var qty = ele.closest('.suggested-product').querySelector('quantity-input [name="quantity"]').value;
        var get_price = window.formatMoney(ele.getAttribute('data-price'));
        var addHtml = `
        <div class="table-row" data-add-id="${ele.getAttribute('data-id')}">
            <div class="title">
                <div class="image"><img src="${main_div.querySelector('.image img').getAttribute('src')}" height="auto" width="auto"></div>
                <div class="product-title">${main_div.querySelector('.product-details .product-title').textContent.trim()}</div>
