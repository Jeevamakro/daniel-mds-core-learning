    function addListItem(ele){
      var rows = document.querySelectorAll('.product-table .table-row');
      if (rows.length === 0) {
          alert('Please add Products to the list before adding to cart.');
          return;
      }

      var items = [];
      rows.forEach(function(row) {
          var variantId = row.getAttribute('data-add-id');
          if (!variantId) return;
          var qtyInput = row.querySelector('input[name="quantity"]');
          var quantity = qtyInput ? parseInt(qtyInput.value, 10) : 1;
          items.push({
              id: parseInt(variantId, 10),
              quantity: quantity > 0 ? quantity : 1
          });
      });

      if (items.length === 0) {
          alert('No valid products found to add to cart.');
          return;
      }

      console.log(items,'items');

      ele.classList.add('disabled');
      ele.textContent = 'Adding...';

      fetch('/cart/add.js', {
          method: 'POST',
          headers: {
              'Content-Type': 'application/json'
          },
          body: JSON.stringify({ items: items })
      })
      .then(function(response){
          if (!response.ok) {
              throw new Error('Failed to add items to cart.');
          }
          return response.json();
      })
      .then(function(data){
          
          var msg = document.querySelector('.success-message');
          msg.textContent = 'items added to Cart';
          if (msg) {
              msg.classList.remove('hidden');
              setTimeout(function() {
                  msg.classList.add('hidden');
              }, 2000);
          }
          ele.classList.remove('disabled');
          ele.textContent = 'Add list to Cart';
          setTimeout(function() {
            document.querySelector('.saved-success-message').classList.add('hidden');
            document.querySelector('.lists-name [name="lits-name"]').value = '';
            document.querySelector('[onkeyup="searchProd(this)"]').value = '';
            document.querySelectorAll('.list-created .product-table .product-list .table-row').forEach((removeRow) => {
                removeRow.remove();
            })
            document.querySelector('.list-created .product-table').classList.add('hidden');
            document.querySelector('.list-created .empty-text').classList.remove('hidden');
            document.querySelector('.list-created .add-producttolist .list-total-price .list-price').innerText = window.formatMoney(0);
            document.querySelector('.list-created .add-producttolist .list-total-price button').classList.add('disabled');
          }, 1500);
          // Optionally, redirect to cart or update cart UI here
      })
      .catch(function(error){
          alert('Error: Could not add items to cart.');
          ele.classList.remove('disabled');
          ele.textContent = 'Add list to Cart';
          console.error(error);
      });
    }

    function listitemscart(ele){

      var row = ele.closest('.table-row');
      var listNameElem = row.querySelector('.list-name a');
      var listTitle = listNameElem.textContent.trim();

      var myLists = localStorage.getItem('mylists');
      if (!myLists) return;

      var myListsArr;
      try {
          myListsArr = JSON.parse(myLists);
      } catch(e){
          console.error("Could not parse mylists", e);
          return;
      }
      if (!Array.isArray(myListsArr)) return;

      var foundIndex = myListsArr.findIndex(function(list) {
          return list.list_title === listTitle;
      });
      if (foundIndex === -1) {
          alert("List not found.");
          return;
      }
      var foundList = myListsArr[foundIndex];

      if (!foundList.products || !Array.isArray(foundList.products) || foundList.products.length === 0) {
          alert("No products in this list.");
          return;
      }
      var items = foundList.products.map(function(p) {
          return { id: p.id, quantity: p.quantity || 1 };
      });

      ele.classList.add('disabled');
      ele.textContent = 'Adding...';

      fetch('/cart/add.js', {
          method: 'POST',
          headers: {
              'Content-Type': 'application/json'
          },
          body: JSON.stringify({ items: items })
      })
      .then(function(response){
          if (!response.ok) {
              throw new Error('Failed to add items to cart.');
          }
          return response.json();
      })
      .then(function(data){
          myListsArr.splice(foundIndex, 1);
          localStorage.setItem('mylists', JSON.stringify(myListsArr));

          var tableBody = document.querySelector('.lists-layout .lists-table');
          if (typeof addsavedEntry === 'function' && myListsArr.length > 0) {
              addsavedEntry(JSON.stringify(myListsArr));
          } else if (tableBody) {
              tableBody.innerHTML = '';
          }

          var msg = document.querySelector('.success-message');
          if (msg) {
              msg.classList.remove('hidden');
              setTimeout(function () {
                  msg.classList.add('hidden');
              }, 2000);
          }
          ele.classList.remove('disabled');
          ele.textContent = 'Add list to Cart';
          checkforlists();
          {% comment %} window.location.href = '/cart'; {% endcomment %}
      })
      .catch(function(error){
          alert('Error: Could not add items to cart.');
          ele.classList.remove('disabled');
          ele.textContent = 'Add list to Cart';
          console.error(error);
      });
    }

    window.addEventListener('scroll', function() {
        closeBox();
    });
</script>

