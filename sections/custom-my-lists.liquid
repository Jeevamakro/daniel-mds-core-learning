    function saveLists(ele){

        var mylists = [];
        // Get the list title value
        var listTitle = document.querySelector('.list-created [name="lits-name"]') ? document.querySelector('.list-created [name="lits-name"]').value.trim() : '';

        console.log(listTitle,'listTitle')
        if(listTitle == ''){
            var errorElem = document.createElement('p');
            errorElem.className = 'error-message';
            errorElem.textContent = 'Please add List title';
            document.querySelector('.lists-name').appendChild(errorElem);
            setTimeout(function() {
                document.querySelector('.lists-name .error-message').remove();
            }, 2000);
            return false;
        }

        if(document.querySelectorAll('.list-created .product-table .table-row').length == 0){
            var errorElem = document.createElement('p');
            errorElem.className = 'error-message';
            errorElem.textContent = 'Please add Products';
            document.querySelector('.lists-name').appendChild(errorElem);
            setTimeout(function() {
                document.querySelector('.lists-name .error-message').remove();
            }, 2000);
            return false;
        }

        // Get today's date in YYYY-MM-DD format
        var today = new Date();
        var addDate = today.getFullYear() + '-' + 
            String(today.getMonth()+1).padStart(2, '0') + '-' + 
            String(today.getDate()).padStart(2, '0');

        // Retrieve previously saved lists, or start with empty
        var existingLists = [];
        var stored = localStorage.getItem('mylists');
        if (stored) {
            try {
                var parsed = JSON.parse(stored);
                // If old object format, coerce to array
                if (Array.isArray(parsed)) {
                    existingLists = parsed;
                } else if (typeof parsed === 'object' && parsed !== null) {
                    existingLists = [parsed];
                }
            } catch(e) {
                existingLists = [];
            }
        }

        // Build new/updated list object
        var listObj = {
            list_title: listTitle,
            date_added: addDate,
            products: []
        };

        document.querySelectorAll('.list-created .product-table .table-row').forEach(function(row) {
            var id = row.getAttribute('data-add-id') || '';
            var title = '';
            var sku = '';
            var image = '';
            var price = '';
            var qty = '';

            var titleDiv = row.querySelector('.product-title');
            if (titleDiv) {
                title = titleDiv.textContent.trim();
            }

            var skuDiv = row.querySelector('.sku');
            if (skuDiv) {
                sku = skuDiv.textContent.replace(/SKU/i, '').replace(/\s+/g, '');
            }

            var imgTag = row.querySelector('img');
            if (imgTag) {
                image = imgTag.getAttribute('src') || '';
            }

            var priceDiv = row.querySelector('.product-price');
            if (priceDiv) {
                price = priceDiv.getAttribute('data-price-v') || '';
            }

            var qtyDiv = row.querySelector('quantity-input [name="quantity"]');
            if (qtyDiv) {
              qty = parseInt(qtyDiv.value) || '';
            }
            
            listObj.products.push({
                id: id,
                title: title,
                sku: sku,
                image: image,
                price: price,
                quantity: qty,
                date_added: addDate
            });
        });

        // Check if a list with the same name exists -- update if so, else add
        var found = false;
        for (var i = 0; i < existingLists.length; i++) {
            if (existingLists[i].list_title === listObj.list_title) {
                // update in place
                existingLists[i] = listObj;
                found = true;
                break;
            }
        }
        if (!found) {
            existingLists.push(listObj);
        }
        localStorage.setItem('mylists', JSON.stringify(existingLists));

        document.querySelector('.saved-success-message').classList.remove('hidden');
        setTimeout(function() {
            document.querySelector('.saved-success-message').classList.add('hidden');
            document.querySelector('.lists-name [name="lits-name"]').value = '';
            document.querySelector('[onkeyup="searchProd(this)"]').value = '';
            document.querySelectorAll('.list-created .product-table .product-list .table-row').forEach((removeRow) => {
                removeRow.remove();
            })
            document.querySelector('.list-created .product-table').classList.add('hidden');
            document.querySelector('.list-created .empty-text').classList.remove('hidden');
            document.querySelector('.list-created .add-producttolist .list-total-price .list-price').innerText = window.formatMoney(0);
            document.querySelector('.list-created .add-producttolist .list-total-price button').classList.add('disabled');

        }, 1500);
    }

