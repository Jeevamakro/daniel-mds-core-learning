    function deleteList(ele){
        
        var row = ele.closest('.table-row');
        if (!row) return;
        
        var listName = row.querySelector('.list-name a') ? row.querySelector('.list-name a').textContent.trim() : null;
        if (!listName) return;
        
        var myLists = localStorage.getItem('mylists');
        if (!myLists) return;

        var myListsObj;
        try {
            myListsObj = JSON.parse(myLists);
        } catch(e){
            console.error('Failed to parse mylists', e);
            return;
        }
        if (Array.isArray(myListsObj)) {
            var newLists = myListsObj.filter(function(list){
                return list.list_title !== listName;
            });
        
            if (newLists.length > 0) {
                localStorage.setItem('mylists', JSON.stringify(newLists));
            } else {
                localStorage.removeItem('mylists');
            }
        } else if (myListsObj && myListsObj.list_title === listName) {
            localStorage.removeItem('mylists');
        }
        
        row.parentNode.removeChild(row);
        
        setTimeout(function() {
            var tableRows = document.querySelectorAll('.lists-table .table-row');
            if (tableRows.length === 0) {
                document.querySelector('.lists-layout').classList.add('hidden');
                document.querySelector('.empty-text').classList.remove('hidden');
            }
        }, 100);
    }

