<style>
    .collection-card {
        position: relative;
        display: inline-block;
        width: auto;
    }
    .collection-showcase-list {
    text-align: center;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    row-gap: 93px;
    column-gap: 154px;
}
.collection-image-preview {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
    opacity: 0;
}
.collection-card:hover .collection-image-preview {
    opacity: 1;
}
.collection-image-preview img {
    border-radius: 50%;
}
.collection-card-header {
    position: relative;
    z-index: 4;
}
</style>
<script>
document.querySelectorAll(".collection-card").forEach(card => {

  const preview = card.querySelector(".collection-image-preview");

  card.addEventListener("mousemove", (e) => {
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    preview.style.left = x + "px";
    preview.style.top = y + "px";
  });

});
</script>

