
{% comment %}
Dependencies (file names)
CSS assets:
- wholesale-order.css            -> Styles for the wholesale order section (layout, product list, controls)
- component-pagination.css  -> Pagination styling

Snippets / rendered partials:
- section-margin            -> Adds configured margin classes for the section.
- icon-dropdown            -> Dropdown arrow/icon used in filter button.
- wholesale-mobile-filter  -> Mobile filter UI used for small screens.
- icon-arrow               -> Arrow icon for pagination prev/next.
{% endcomment %}

{{ 'wholesale-order.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-pagination.css' | asset_url }}" media="print" onload="this.media='all'">
<script src='{{ 'wholesale-order.js' | asset_url }}' defer='defer'></script>
{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}
<div class="container" >
    <div class="search-bar bundle-search-bar" >
        <div class="custom-select" >
            <div class="select-wrap" >
                <div class="select-styled" >
                    Sort by
                </div>
                <ul class="select-options" style="display: none;">
                    <li data-title="Alphabetically: A-Z" class="is-selected"><input type="radio" name="sort-by" value="manual"><span class="sort-by-item">Alphabetically: A-Z</span></li>
                    <li data-title="Alphabetically: Z-A"><input type="radio" name="sort-by" value="manual"><span class="sort-by-item">Alphabetically: Z-A</span></li>
                    <li data-title="SKU"><input type="radio" name="sort-by" value="manual"><span class="sort-by-item">SKU</span></li>
                </ul>
            </div>
        </div>
        <div class="wholesale-filter-dropdown">
            <button class="desktop-filter filter-btn button">Filter
            {% render 'icon-dropdown' %}
        </button>
        <div class="desktop-filter-menu filter-menu">
            <label><input type="checkbox" value="red"> Red</label>
            <label><input type="checkbox" value="green"> Green</label>
            <label><input type="checkbox" value="blue"> Blue</label>
            <label><input type="checkbox" value="yellow"> Yellow</label>
        </div>
        </div>
        <div class="searchbar" >
