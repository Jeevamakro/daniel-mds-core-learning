              <path d="M12.0877 12.8027C12.2852 13.0001 12.6053 13.0001 12.8027 12.8027C13.0001 12.6053 13.0001 12.2852 12.8027 12.0877L12.0877 12.8027ZM10.0181 6.03999C10.0181 8.23703 8.23703 10.0181 6.03999 10.0181V11.0292C8.79545 11.0292 11.0292 8.79545 11.0292 6.03999H10.0181ZM6.03999 10.0181C3.84295 10.0181 2.06189 8.23703 2.06189 6.03999H1.05078C1.05078 8.79545 3.28453 11.0292 6.03999 11.0292V10.0181ZM2.06189 6.03999C2.06189 3.84295 3.84295 2.06189 6.03999 2.06189V1.05078C3.28453 1.05078 1.05078 3.28453 1.05078 6.03999H2.06189ZM6.03999 2.06189C8.23703 2.06189 10.0181 3.84295 10.0181 6.03999H11.0292C11.0292 3.28453 8.79545 1.05078 6.03999 1.05078V2.06189ZM8.88514 9.6001L12.0877 12.8027L12.8027 12.0877L9.6001 8.88514L8.88514 9.6001Z" fill="#3F3F3F"/>
            </svg>
            <input type="text" placeholder="SEARCH BY" onkeyup="filter_bar()">
        </div>
    </div>
        <div class="most-purchased-items-list most-purchased-product-list swiper" >
          <div class="swiper-wrapper" >
          </div>
        </div>
