	},
  {
      "type": "color",
      "id": "card_background",
      "default": "#f2f2f2",
      "label": "Collection card Background-color"
  },
  {
            "type": "select",
            "id": "button_style",
            "options": [
                {
                    "value": "primary",
                    "label": "t:sections.all.button.button_style.options__1.label"
                },
                {
                    "value": "secondary",
                    "label": "t:sections.all.button.button_style.options__2.label"
                },
                {
                    "value": "tertiary",
                    "label": "t:sections.all.button.button_style.options__3.label"
                }
            ],
            "default": "primary",
            "label": "t:sections.all.button.button_style.label"
  },
  {
			"type": "range",
			"id": "columns_per_row_version1",
			"min": 2,
			"max": 4,
			"step": 1,
			"default": 3,
			"label": "t:sections.all.columns.label",
      "info": "Column per row style apply for Version 1",
      "visible_if": "{{ section.settings.versions == 'version1' }}"
