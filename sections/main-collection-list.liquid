{%- comment -%}
  SECTION: Main Collection List
  CATEGORY: Collection

  DESCRIPTION:
  - Displays all store collections in a responsive grid layout.
  - Supports two display versions (Version 1 and Version 2), each with distinct layout and column configuration options.
  - Allows merchants to choose image source (featured image or metafield image).
  - Includes customizable background color for the collection card image container.
  - Provides responsive column controls for both desktop and mobile layouts.

  LOGIC OVERVIEW:
  - Determines which layout to render based on `section.settings.versions`:
      → If 'version1' is selected:
          • Renders the Version 1 layout.
          • Uses `section.settings.columns_per_row_version1` to determine the number of columns.
      → If 'version2' is selected:
          • Renders the Version 2 layout.
          • Uses `section.settings.columns_per_row` for desktop and `section.settings.columns_mobile` for mobile.
  - Determines collection image source:
      → Uses `collection.featured_image` if `image_source` is set to 'featured_image'.
      → Otherwise uses `collection.metafields.custom.additional_image`.
  - Dynamically applies grid layout classes based on the selected version and column count.
  - Applies inline background color style from `section.settings.card_background`.
  - Includes section margin spacing logic through the `section-margin.liquid` snippet.

  DEPENDENCIES:
  - CSS:
      • main-collection-list.css
  - SNIPPETS:
      • section-margin.liquid
  - ASSETS:
      • Placeholder SVG (used when no collection image is available)

  NOTES:
  - Separate “columns per row” settings exist for Version 1 and Version 2 layouts.
  - Version 2 additionally supports mobile column control.
  - Background color customization applies to the collection card container.
  - Section margin settings support both desktop and mobile spacing.
{%- endcomment -%}

{{- 'main-collection-list.css' | asset_url | stylesheet_tag -}}
{%- style -%}
	{% render 'section-margin' %}
  .custom-collection-grid .collection-path{ background-color: {{ section.settings.card_background }}; }
{%- endstyle -%}


<div class='main-list-collections-page'>
    <div class="container">
        <div class='page-header__inner'>
          <h1 class='main-page-title page-title title--page {{section.settings.section_heading_size}}'>
            {{ section.settings.title | escape }}
          </h1>
		     </div>
      {% comment %} version 1 {% endcomment %}         
      {% if section.settings.versions == 'version1' %}
          {% assign column_per_row_version1 = section.settings.columns_per_row_version1 %}
          <div class=" {{ section.settings.version }} collections-list__wrapper {% if section.settings.versions == 'version1' %} version-1 {% endif %}  collections-list__wrapper--{{ column_per_row_version1 }} ">
            {%- for collection in collections -%}
                {% liquid
              if section.settings.image_source == 'featured_image'
                assign collection_image = collection.featured_image
              else
                assign collection_image = collection.metafields.custom.additional_image
              endif
            %}
                <div class="collections-list__item">
                    <div class="collection-inner">
                        {% if collection_image != blank %}
                            <div class="collection-path">
                                <a href="{{ collection.url }}">   {{
                                        collection_image
                                            | image_url: width: collection_image.width
                                            | image_tag:
                                        loading: 'lazy',
                                        widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200',
                                        sizes: sizes
                                    }} </a>
                            </div>
                        {% else %}
                        {{
                            'detailed-apparel-1'
                            | placeholder_svg_tag: 'placeholder-svg'
                        }}
                        {% endif %}
                    </div>
                    <div class="collection-content">
                    <h5 class="collection-title"><a href='{{ collection.url }}'class='collections-list__link' aria-label='{{ collection.title }}'>{{ collection.title }}</a></h5>
                    </div>
                    <div class="collection-inner-link">
                     {% assign button_style = section.settings.button_style %}
                       <div class="collection-link"><a href='{{ collection.url }}'class='collections__link button {% if button_style == 'primary' %} button--primary {% elsif button_style == 'secondary' %} button--secondary {% elsif button_style == 'tertiary' %} button--tertiary {% endif %}' aria-label='{{ collection.title }}'>{% render 'custom-collection-arrow' %}</a></div>
                    </div>
                </div>
            {% endfor %}
          </div>
      {% endif %}

       {% comment %} version 2 {% endcomment %}
       {% if section.settings.versions == 'version2' %}
       {% assign column_per_row = section.settings.columns_per_row %}
          <div class=" {{ section.settings.version }} collections-list__wrapper  {% if section.settings.versions == 'version2' %} version-2 {% endif %} collections-list__wrapper--{{ column_per_row }}  collections-list__wrapper-mobile--{{ section.settings.columns_mobile }} ">
            {%- for collection in collections -%}
                {% liquid
              if section.settings.image_source == 'featured_image'
                assign collection_image = collection.featured_image
              else
                assign collection_image = collection.metafields.custom.additional_image
              endif
            %}
                <div class="collections-list__item">
                    <div class="collection-inner">
                        {% if collection_image != blank %}
                            <div class="collection-path">
                                <a href="{{ collection.url }}">   {{
                                        collection_image
                                            | image_url: width: collection_image.width
                                            | image_tag:
                                        loading: 'lazy',
                                        widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200',
                                        sizes: sizes
                                    }} </a>
                            </div>
                        {% else %}
                        {{
                            'detailed-apparel-1'
                            | placeholder_svg_tag: 'placeholder-svg'
                        }}
                        {% endif %}
                    </div>
                    <div class="collection-content">
                    <h4 class="collection-title"><a href='{{ collection.url }}'class='collections-list__link' aria-label='{{ collection.title }}'>{{ collection.title }}</a></h4>
                    </div>
                </div>
            {% endfor %}
          </div>
        {% endif %}
    </div>
</div>

{% schema %}
{
  "name": "Collection list",
  "class": "custom-collection-grid",
  "settings": [
    {
			"type": "text",
			"id": "title",
			"label": "t:sections.main-list-collections.settings.title.label",
			"default": "Collections"
	},
  {
			"type": "select",
			"id": "image_source",
			"options": [
				{
					"value": "featured_image",
					"label": "t:sections.main-list-collections.settings.image_source.options__1.label"
				},
				{
					"value": "additional_image",
					"label": "t:sections.main-list-collections.settings.image_source.options__2.label"
				}
			],
			"default": "featured_image",
