<section class="css-loop-slider">
  <div class="slider-wrapper">

    {% assign total = section.blocks.size %}

    {%- for block in section.blocks -%}
      <input
        type="radio"
        name="slider-{{ section.id }}"
        id="slide-{{ section.id }}-{{ forloop.index }}"
        {% if forloop.first %}checked{% endif %}
      >
    {%- endfor -%}

    <!-- Slides -->
    <div class="slides">
      {% for block in section.blocks %}
        <div class="slide" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 2000 }}"
              alt="{{ block.settings.heading | escape }}"
              loading="lazy"
            >
          {% endif %}

          <div class="slide-content">
            {% if block.settings.heading != blank %}
              <h2>{{ block.settings.heading }}</h2>
            {% endif %}

            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}

            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="btn">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- ARROWS -->
    {% if section.settings.pagination_style == 'arrows' or section.settings.pagination_style == 'both' %}
    <div class="slider-arrows">
      {% for block in section.blocks %}
        {% assign index = forloop.index0 %}
        
        {% if section.settings.enable_loop %}
          {% assign prev = index | minus: 1 %}
          {% if prev < 0 %}
            {% assign prev = total | minus: 1 %}
          {% endif %}

          {% assign next = index | plus: 1 %}
          {% if next >= total %}
            {% assign next = 0 %}
          {% endif %}
        {% else %}
          {% assign prev = index | minus: 1 %}
          {% assign next = index | plus: 1 %}
        {% endif %}

        <div class="arrow-set arrow-{{ forloop.index }}">
          
          {% if section.settings.enable_loop or prev >= 0 %}
            <label for="slide-{{ section.id }}-{{ prev | plus: 1 }}" class="prev">&#10094;</label>
          {% endif %}

          {% if section.settings.enable_loop or next < total %}
            <label for="slide-{{ section.id }}-{{ next | plus: 1 }}" class="next">&#10095;</label>
          {% endif %}

        </div>
      {% endfor %}
    </div>
    {% endif %}

    <!-- DOTS -->
    {% if section.settings.pagination_style == 'dots' or section.settings.pagination_style == 'both' %}
    <div class="slider-dots">
      {% for block in section.blocks %}
        <label for="slide-{{ section.id }}-{{ forloop.index }}"></label>
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

<style>
.css-loop-slider {
  position: relative;
  overflow: hidden;
}

.slider-wrapper input {
  display: none;
}

.slides {
  display: flex;
  transition: transform 0.6s ease;
}

.slide {
  min-width: 100%;
  position: relative;
}

.slide img {
  width: 100%;
  height: 600px;
  object-fit: cover;
  display: block;
}

.slide-content {
  position: absolute;
  top: 50%;
  left: 10%;
  transform: translateY(-50%);
  color: #fff;
  max-width: 500px;
}

.slide-content h2 {
  font-size: 40px;
  margin-bottom: 15px;
}

.slide-content p {
  font-size: 18px;
  margin-bottom: 20px;
}

.btn {
  background: #000;
  color: #fff;
  padding: 12px 26px;
  text-decoration: none;
}

/* Slide movement */
{% for block in section.blocks %}
#slide-{{ section.id }}-{{ forloop.index }}:checked ~ .slides {
  transform: translateX(-{{ forloop.index0 }}00%);
}
{% endfor %}

/* ===== DOTS ===== */
.slider-dots {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
}

.slider-dots label {
  width: 12px;
  height: 12px;
  background: #fff;
  opacity: 0.5;
  border-radius: 50%;
  cursor: pointer;
}

{% for block in section.blocks %}
#slide-{{ section.id }}-{{ forloop.index }}:checked
~ .slider-dots label:nth-child({{ forloop.index }}) {
  opacity: 1;
}
{% endfor %}

/* ===== ARROWS ===== */
.slider-arrows label {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.5);
  color: #fff;
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.slider-arrows .prev { left: 20px; }
.slider-arrows .next { right: 20px; }

.slider-arrows .arrow-set {
  display: none;
}

{% for block in section.blocks %}
#slide-{{ section.id }}-{{ forloop.index }}:checked
~ .slider-arrows .arrow-{{ forloop.index }} {
  display: block;
}
{% endfor %}

@media(max-width: 768px){
  .slide img { height: 400px; }
  .slide-content h2 { font-size: 26px; }
  .slide-content p { font-size: 14px; }
}
</style>

{% schema %}
{
  "name": "CSS Slider With Loop",
  "settings": [
    {
      "type": "select",
      "id": "pagination_style",
      "label": "Pagination Style",
      "default": "both",
      "options": [
        { "value": "dots", "label": "Dots Only" },
        { "value": "arrows", "label": "Arrows Only" },
        { "value": "both", "label": "Dots + Arrows" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable Circular Loop",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Slide Heading" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Slide description here." },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "CSS Slider With Loop",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
