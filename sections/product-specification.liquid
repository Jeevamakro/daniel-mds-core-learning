{{ 'product-specification.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-specifications.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="product-specifications section-{{ section.id }}-padding" id="product-specifications">
  <div class="container">
    <div class="product-specifications__wrapper">
      {% render 'section-header',
        section_heading: section.settings.section_heading,
        section_subheading: section.settings.section_subheading,
        dot: section.settings.dot,
        section_heading_size: section.settings.section_heading_size
      %}
	  {% if product.metafields.custom.specifications != blank or product.metafields.custom.documents != blank %}
      <div class="product-specifications-main-container">
        <div class="product-specifications__content">

			{% if product.metafields.custom.specifications != blank %}
			<div class="product-specifications__items">
				<div class="product-specifications__item{% if block.settings.default_open %} active{% endif %}">
				<button class="product-specifications__toggle focus-inset button--unstyled" aria-label="{{ block.settings.question | escape }}">
					<div class="product-specifications__toggle-group">
					<h3 class="product-specifications__question">Specification</h3>
					</div>
					<div class="product-specifications__icon icon-style--{{ section.settings.icon_style }}">
					{% render 'icon-minus' %}
					{% render 'icon-plus' %}
					</div>
				</button>
				<div
					class="product-specifications__answer product-specifications__answer_no-image"
					{% if block.settings.default_open %} style="display: block;" {% endif %}>
					{% if product.metafields.custom.specifications != blank %}
						<div class="product-spec-feat-wrapper"></div>

						<script>
							var tableJSON = "";
							tableJSON = {{ product.metafields.custom.specifications | replace:'=>',':' }};
							var data = tableJSON;
				
							var lookup = {};
							var result = [];
							var data1 = data['Values'];
				
							for (var data1, i = 0; item = data1[i++];) {
								let has_additional = false;
								if(item[1] == 'Additional Information' || item[1] == 'additional information'){
									has_additional = true;          
									lookup[item[1]] = [];          
									lookup[item[1]]["hideKey"] = [];
									if(item[2].includes("•")){
									var removeDotFromData = item[2].replace(/<br\/?>/gi,'').replace(/[\r\n]+/g,'');
									removeDotFromData = removeDotFromData.split("•");
									for(let j=1; j<removeDotFromData.length; j++){
										lookup[item[1]]["hideKey"].push(removeDotFromData[j].trim());
									}
									}else{
									lookup[item[1]]["hideKey"].push(item[2]);
									}
								}else if(item[2].includes("•")){
									has_additional = true;
									lookup[item[0]] = [];          
									lookup[item[0]]["keyValues"] = [];          
									lookup[item[0]]["keyValues"].push(item[1]);
									var removeDotFromData = item[2].replace(/<br\/?>/gi,'').replace(/[\r\n]+/g,'');
									removeDotFromData = removeDotFromData.split("•");
									for(let j=1; j<removeDotFromData.length; j++){
										lookup[item[0]]["keyValues"].push(removeDotFromData[j].trim());
									}
								}
								if( !has_additional ){
									var name = item[0];
									if (!(name in lookup)) {
									lookup[name] = [];
									result.push(name);
									lookup[name].push({ [item[1]]: item[2] });
									}else{
									lookup[name].push({ [item[1]]: item[2] });
									}
								}        
							}
				
							html = '';
							/*html += '<h2>Specifications</h2>';*/
							var additionalInfo = false;
				
							html = '<div class="product-spec-column-left">';
							let add_class = '';

							Object.keys(lookup).forEach(function(key, index) {
								const keyValue = lookup[key];
								const keyHeading = key;
								
								if(index == 4){
									html += '</div><div class="product-spec-column-right">';
								}

								html += '<div class="spec-feat-item"><h4 class="spec-feat-title h4">'+keyHeading+'</h4>';
								html += `<ul class="spec-feat-list">`;
							
								if( keyValue.length ){
									for (let i = 0; i < keyValue.length; i++ ){
										var html_td = '', has_dots = false;
										for (const [key, value] of Object.entries(keyValue[i])) {
											if(value.includes("•") && has_dots == false){
												has_dots = true;
											}
											if( !has_dots ){
												html_td = html_td + (key != "hideKey" ? `<li><span class="spec-name">${key}</span>`: '');
											}else{
												html_td = html_td + (key != "hideKey" ? `<li><span class="spec-name">${key}</span>`: '');
											}                    
											if( keyHeading == "Warranty" ){
												{%- if has_spec_tag and spec_tag_data != blank -%}
													html_td += `<td>{{ spec_tag_data }}</td>`;
												{%- else -%}
													if( !has_dots ){
														html_td += `<td>${value}</td>`;
													}else{
														html_td += `<div class="value">${value}</div>`;
													}
												{%- endif -%}  
											}else{                      
												if( !has_dots ){
													html_td += `<span class="spec-value">${value}</span>`;
												}else{
													html_td += `<li><span class="spec-value">${value}</span>`;
												}
											}              
										}
										
										var html_tr = `${ html_td }</li>`;
										if( has_dots ){
											html_tr = `<tr class="has_dots"><td><div class="td-wrapper">${ html_td }</div></td><td></td></tr>`;
										}
										
										html += html_tr;
									}
								}else{
									if( keyValue.hideKey ){
										add_class = ''
										html += ''
										for (let i = 0; i < keyValue.hideKey.length; i++ ){
											html += `<li><span class="spec-value">${keyValue.hideKey[i]}</span></li>`;
										}
									}else if(keyValue.keyValues){
										var html_td = '';
										html_td = html_td + `<li class="listed-values"><span class="spec-name">${keyValue.keyValues[0]}</span><ul>`;
										for (var j=1; j<keyValue.keyValues.length; j++) {
											html_td = html_td + `<li><span class="spec-value">${keyValue.keyValues[j]}</span></li>`;
										}
										html_td = html_td + `</ul>`;
										html += html_td;
									}
								}
								html += `</ul></div>`;
							})        
							html += `</div>`;
							document.querySelector('#product-specifications') && (document.querySelector('.product-specifications__answer .product-spec-feat-wrapper').innerHTML = html);
						</script>
					{% endif %}
				</div>
				</div>
			</div>
			{% endif %}

			{% if product.metafields.custom.documents != blank %}
			<div class="product-specifications__item">
				<button
				class="product-specifications__toggle focus-inset button--unstyled"
				aria-label="{{ block.settings.question | escape }}">
				<div class="product-specifications__toggle-group">
					<h3 class="product-specifications__question">Documents</h3>
				</div>
				<div class="product-specifications__icon icon-style--{{ section.settings.icon_style }}">
					{% render 'icon-minus' %}
					{% render 'icon-plus' %}
				</div>
				</button>
				
				<div
				class="product-specifications__answer {% if item.image == blank %} product-specifications__answer_no-image {% endif %}"
				{% if block.settings.default_open %} style="display: block;"{% endif %}>
					
					<div class="product-document-wrapper"></div>

					<div class="document_part content--part"></div>        
					<script>
						var documentJSON = "";              
						documentJSON = {{ product.metafields.custom.documents | replace:'=>',':' }};            
						var dataq = documentJSON;
						var data2 = dataq['Values'];
						if(data2){
							let doc_html = '';
							let engLangTitleText = {
								"installation" : "Installation guide",
								"manual" : "Owner's manual",
								"specs" : "Product specification",
								"energy" : "Energy guide",
								"warranty" : "Warranty Details",
								"assembly" : "Assembly Guide",
								"dimensions" : "Dimension sheet",
								"additional" : "Additional documents"
							}

							doc_html += '<ul class="product-document-list">';
							for (const [key, value] of Object.entries(dataq['Values'])) {              
							let doc_link = value[1].replace("http://","https://");
							let valTitle = engLangTitleText[value[0]];
							doc_html += `
							<li class="product-document-item">
								<a href="${doc_link}" class="h4 product-document-link" target="_blank" rel="">
								<span class="product-document-icon">
									{% render 'icon-document' %}
								</span>
								<span class="product-document-name">${ valTitle }</span>
								</a>
							</li>`;
							doc_html += '</span></a></li>'; 
							}
							doc_html += '</ul>';
							document.querySelector('.product-specifications__wrapper .product-document-wrapper').innerHTML += doc_html;

						}
					</script>
				</div>
			</div>
			{% endif %}

        </div>
      </div>
	  {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.product-specifications.name",
  "tag": "section",
  "class": "product-specifications-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.product-specifications.settings.paragraph.content"
    },
    {
      "type": "select",
      "id": "icon_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.icon_styles.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.icon_styles.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.icon_styles.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.icon_styles.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "default": "Some heading",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "section_subheading",
      "default": "Subheading",
      "label": "t:sections.all.section-header.subheading.label"
    },
    {
      "type": "checkbox",
      "id": "dot",
      "default": true,
      "label": "t:sections.all.section-header.dot.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "s",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "s",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "Product specifications and feature"
    }
  ]
}
{% endschema %}
