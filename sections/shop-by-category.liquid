{%- comment -%}
------------------------------------------------------------------------------
  SECTION: Shop by Category
  FILE: shop-by-category.liquid

  PURPOSE:
  Displays a grid / slider of category cards with image and title.
  Supports multiple layout versions and optional mobile swipe.

  LOGIC OVERVIEW:
  - Uses section blocks to render category cards (image + heading + link)
  - Supports two layout versions (version1 / version2)
  - Desktop layout uses CSS grid with configurable columns
  - Mobile can switch between grid and Swiper slider
  - Image aspect ratio handled via CSS custom property (--aspect-ratio)
  - Section margin and padding handled via shared snippets

  DEPENDENCIES:
  - CSS: shop-by-category.css
  - JS: shop-by-category.js
  - Snippets:
    - section-header
    - section-margin
    - section-padding
  - Library: Swiper (only when swipe_on_mobile is enabled)

  SETTINGS:
  - Columns per row (desktop)
  - Mobile columns & swipe toggle
  - Section heading, subheading, dot indicator
  - Image aspect ratio (fixed or adapt)
  - Color scheme
  - Section margin & padding controls

  BLOCKS:
  - Category Card
    - Image
    - Heading text
    - Optional link
Note: custom section
------------------------------------------------------------------------------
{%- endcomment -%}

{{ 'shop-by-category.css' | asset_url | stylesheet_tag }}
<script src='{{ 'shop-by-category.js' | asset_url }}' defer='defer'></script>

{% liquid
	assign columns_per_row = section.settings.columns_per_row
%}

{%- style -%}
	{% render 'section-margin' %}
    {% render 'section-padding' %}
	{% for block in section.blocks %}
	.shop-category-section .version1 .card-list__item_img{  background-color:{{ section.settings.card_background }}; } 
	{% endfor %}
{%- endstyle -%}

<div 
	class='card-listt color-{{ section.settings.color_scheme }}'
	data-id='shopify-section-{{ section.id }}'
	id="card-list"
>
	<div class='container section-{{ section.id }}-padding'>
		{% render 'section-header',
			section_heading: section.settings.section_heading,
			section_subheading: section.settings.subheading,
			section_heading_size: section.settings.section_heading_size,
			dot: section.settings.dot
		%}
          {% comment %} version 1 {% endcomment %}         
        {% if section.settings.versions == 'version1' %}
            <div class='{% if section.settings.swipe_on_mobile %}swiper card-list__swiper{% endif %} {{ section.settings.versions }}'>
                {% comment %} <div class='card-list-pagination swiper-pagination'></div> {% endcomment %}
                <ul class='card-list__list card-list__list--{{ columns_per_row }} {% if section.settings.swipe_on_mobile %}swiper-wrapper{% endif %} columns_mobile--{{section.settings.columns_mobile}}'>
                    {% for block in section.blocks %}
                        
                        <li
                            class='card-list__item {% if block.settings.text != blank %} card-list__item_active {% endif %} {% if section.settings.swipe_on_mobile %}swiper-slide{% endif %}'
                            data-id='{{ block.id }}'
                        >
                        {% if block.settings.text_link != blank %}<a class="shop-card-link" href="{{ block.settings.text_link }}" aria-label="Card link"></a> {% endif %}
                        {% if block.settings.image %}
                            {% liquid
                                assign adapt_height = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 
                            %}
                        {% else %}
                            {% liquid
                                assign adapt_height = 58 
                            %}
                        {% endif %}
                        {% style %}
                            #shopify-section-{{ section.id }} [data-id="{{ block.id }}"].card-list__item .card-list__item_img  {
                                {% if section.settings.image_ratio == 'adapt' %}
                                    --aspect-ratio: {{adapt_height}};
                                {% else %}
                                    --aspect-ratio: {{ section.settings.image_ratio }};
                                {% endif %}
                            }
                        {% endstyle %}
                            <div class='card-list__item_img {% if block.settings.text != blank %} card-list__item_img_active {% endif %} {% if section.settings.image_ratio != 'adapt' %} item_aspect_ratio {% endif %}  '>
                                {%- if block.settings.image != blank -%}
                                    {%- assign widths = '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800' -%}
                                    {%- capture sizes -%}
                                        (min-width: 1200px) calc((100vw - 128px)), calc((100vw - 40px))
                                        {%- endcapture -%}
                                    {{
                                        block.settings.image
                                        | image_url: width: block.settings.image.width
                                        | image_tag: loading: 'lazy', sizes: sizes, widths: widths
                                    }}
                                {%- else -%}
                                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                                {% endif %}
                            </div>
                            {%- if block.settings.text != blank -%}
                                <div class='block-text {{ section.settings.card_heading_size }}'>
                                    {{ block.settings.text }}
                                </div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
         {% if section.settings.versions == 'version2' %}
            <div class='{% if section.settings.swipe_on_mobile %}swiper card-list__swiper{% endif %} {{ section.settings.versions }}'>
                <div class='card-list-pagination swiper-pagination'></div>
                <ul class='card-list__list card-list__list--{{ columns_per_row }} {% if section.settings.swipe_on_mobile %}swiper-wrapper{% endif %} columns_mobile--{{section.settings.columns_mobile}}'>
                    {% for block in section.blocks %}
                       
                        <li
                            class='card-list__item  {% if block.settings.text != blank %} card-list__item_active {% endif %} {% if section.settings.swipe_on_mobile %}swiper-slide{% endif %}'
                            data-id='{{ block.id }}'
                        >
                        {% if block.settings.text_link != blank %}<a class="shop-card-link" href="{{ block.settings.text_link }}" aria-label="Card link"></a> {% endif %}
                         {% if block.settings.image %}
                            {% liquid
                                assign adapt_height = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 
                            %}
                        {% else %}
                            {% liquid
                                assign adapt_height = 58 
                            %}
                        {% endif %}
                        {% style %}
                            #shopify-section-{{ section.id }} [data-id="{{ block.id }}"].card-list__item .card-list__item_img {
                                {% if section.settings.image_ratio == 'adapt' %}
                                    --aspect-ratio: {{adapt_height}};
                                {% else %}
                                    --aspect-ratio: {{ section.settings.image_ratio }};
                                {% endif %}
                            }
                        {% endstyle %}
                            <div class='card-list__item_img {% if block.settings.text != blank %} card-list__item_img_active {% endif %} {% if section.settings.image_ratio != 'adapt' %} item_aspect_ratio {% endif %}'>
                                {%- if block.settings.image != blank -%}
                                    {%- assign widths = '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800' -%}
                                    {%- capture sizes -%}
                                        (min-width: 1200px) calc((100vw - 128px)), calc((100vw - 40px))
                                        {%- endcapture -%}
                                    {{
                                        block.settings.image
                                        | image_url: width: block.settings.image.width
                                        | image_tag: loading: 'lazy', sizes: sizes, widths: widths
                                    }}
                                {%- else -%}
                                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                                {% endif %}
                            </div>
                            {%- if block.settings.text != blank -%}
                                <div class='block-text {{ section.settings.card_heading_size }}'>
                                    {{ block.settings.text }}
                                </div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
	</div>
</div>

{% schema %}
