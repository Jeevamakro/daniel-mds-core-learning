
{{ "custom-form.css" | asset_url | stylesheet_tag }}
<script src='{{ 'custom-form.js' | asset_url }}' defer='defer'></script>

<div class="custom-form">
    <div class="container">
        <form id="contactForm">
      
            <div class="form-group">
                <label>First Name *</label>
                <input type="text" id="fname">
                <div class="error" id="nameError">First Name is required</div>
            </div>

            <div class="form-group">
                <label>Last Name</label>
                <input type="text" id="lname">
            </div>

            <div class="form-group">
                <label>Email *</label>
                <input type="text" id="email">
                <div class="error" id="emailError">Enter a valid email</div>
            </div>

            <div class="form-group">
                <label>Name of your business *</label>
                <input type="text" id="bname">
                <div class="error" id="bnameError">Business Name is required</div>
            </div>

            <div class="form-group">
                <label>Tax ID/EIN number *</label>
                <input type="text" id="taxnumber">
                <div class="error" id="taxnumberError">Tax ID/EIN number is required</div>
            </div>

            <div class="form-group">
                <label>Resale Certificate Number *</label>
                <input type="text" id="resale_certificate_number">
                <div class="error" id="rcnumberError">RESALE CERTIFICATE NUMBER is required</div>
            </div>

            <div class="form-group">
                <label>Your Shipping Address *</label>
                <input type="text" id="shipping_address">
                <div class="error" id="addressError">Shipping Address is required</div>
            </div>

            <div class="form-group">
                <label>Zip Code *</label>
                <input type="text" id="zipcode">
                <div class="error" id="zipcodeError">Zip Code is required</div>
            </div>

            <div class="form-group">
                <label>Country *</label>
                <select id="country" class="form-select">
                    <option value="">PLEASE SELECT</option>
                    <option value="country_1">Country 1</option>
                    <option value="country_2">Country 2</option>
                </select>
                <div class="error" id="countryError">Country is required</div>
            </div>

            <div class="form-group">
                <label>State / Province *</label>
                <select id="state" class="form-select">
                    <option value="">PLEASE SELECT</option>
                    <option value="state_1">State 1</option>
                    <option value="state_2">State 2</option>
                </select>
                <div class="error" id="stateError">State / Province is required</div>
            </div>

            <div class="form-group">
                <label>City *</label>
                <select id="city" class="form-select">
                    <option value="">PLEASE SELECT</option>
                    <option value="city_1">City 1</option>
                    <option value="city_2">City 2</option>
                </select>
                <div class="error" id="cityError">City is required</div>
            </div>

            <div class="form-group">
                <label>Country Code *</label>
                <input type="number" id="countryCode" class="input" placeholder="+">
                <div class="error" id="countryCodeError">Country code is required</div>
            </div>

            <div class="form-group">
                <label for="phoneNumber">Phone Number *</label>
                <input type="number" id="phoneNumber" class="input" placeholder="PHONE NUMBER">
                <div class="error" id="phoneNumberError">Phone number is required</div>
            </div>


            <button type="submit" class="button button--primary">Submit</button>
        </form>
    </div>
</div>


{% schema %}
    {
        "name": "Custom Form",
        "settings": [],
        "presets": [
            {
                "name": "Custom Form"
            }
        ]
    }
{% endschema %}