<section class="wavy-marquee-section" 
  style="--bg-color: {{ section.settings.bg_color }};
         --text-color: {{ section.settings.text_color }};
         --speed: {{ section.settings.speed }}s;">

  <div class="wavy-marquee-wrapper">
    <div class="wavy-marquee-track" id="wavyMarqueeTrack-{{ section.id }}">
      
      {% for block in section.blocks %}
        <span class="wavy-marquee-item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </span>
      {% endfor %}

    </div>
  </div>
</section>

<style>
.wavy-marquee-section {
  background: var(--bg-color);
  color: var(--text-color);
  overflow: hidden;
  width: 100%;
  padding: 20px 0;
}

.wavy-marquee-wrapper {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.wavy-marquee-track {
  display: flex;
  gap: 60px;
  white-space: nowrap;
  animation: marqueeMove linear infinite;
  animation-duration: var(--speed);
}

.wavy-marquee-item {
  font-size: 28px;
  font-weight: 600;
  display: inline-block;
  animation: wave 2s ease-in-out infinite;
}

/* Horizontal scrolling */
@keyframes marqueeMove {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* Wavy vertical motion */
@keyframes wave {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

/* Optional stagger effect */
.wavy-marquee-item:nth-child(odd) {
  animation-delay: 0.3s;
}

.wavy-marquee-item:nth-child(even) {
  animation-delay: 0.6s;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const track = document.getElementById("wavyMarqueeTrack-{{ section.id }}");
  if (!track) return;

  // Duplicate content for seamless infinite effect
  track.innerHTML += track.innerHTML;
});
</script>

{% schema %}
{
  "name": "Wavy Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation Speed (seconds)",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 15
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Worldwide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wavy Marquee",
      "blocks": [
        { "type": "text_item" },
        { "type": "text_item" },
        { "type": "text_item" }
      ]
    }
  ]
}
{% endschema %}